# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# 你的 Telegram User ID（通过 @userinfobot 获取），只有此用户可以使用 Bot
TELEGRAM_ALLOWED_USER_ID=123456789

# 火山引擎 ASR (极速版)
ASR_APP_KEY=your-volcengine-app-key
ASR_ACCESS_TOKEN=your-volcengine-access-token

# LLM (OpenAI 兼容接口)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=deepseek-v3-2-251201

# Notion
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# 数据存储路径
DATA_DIR=./data

# 时区（影响日期分组、定时任务触发时间）
TZ=Asia/Shanghai

# 定时任务：每晚自动整理日记的时间 (基于上面配置的时区)
DIARY_SCHEDULE_HOUR=22
DIARY_SCHEDULE_MINUTE=0
